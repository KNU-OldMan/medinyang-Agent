# ---------------------------
# Upstage (LLM / Embeddings)
# ---------------------------
UPSTAGE_API_KEY=your_upstage_api_key_here
UPSTAGE_CHAT_MODEL=solar-pro2
UPSTAGE_EMBEDDING_MODEL=solar-embedding-1-large

# ---------------------------
# ChromaDB
# local: PersistentClient (file-based)
# server: HttpClient
# ---------------------------
CHROMA_MODE=local
CHROMA_PERSIST_PATH=./chroma_db
CHROMA_COLLECTION_NAME=medinyang_medical_knowledge

# If CHROMA_MODE=server
CHROMA_HOST=localhost
CHROMA_PORT=8000

# ---------------------------
# External Search (Optional)
# ---------------------------
SERPER_API_KEY=your_serper_api_key_here

# ---------------------------
# App
# ---------------------------
APP_ENV=local
LOG_LEVEL=INFO
